<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="750.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.AAdministrador">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Label text="PARKUQ - Panel de Administrador" textFill="#2c3e50">
                            <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <Separator orientation="VERTICAL" />
                        <Label fx:id="usuarioLogueadoLabel" text="Admin: Conectado" textFill="#7f8c8d" />
                        <Button onAction="#handleRestablecerDatosFabrica" style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;" text="⚠️ Restablecer de Fábrica" />
                        <Button onAction="#handleCerrarSesion" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" text="Cerrar Sesión" />
                    </children>
                </HBox>

                <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab text="Espacios">
                            <content>
                                <VBox spacing="15.0">
                                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                                    <children>
                                        <Label text="GESTIÓN DE ESPACIOS"><font><Font name="System Bold" size="14.0" /></font></Label>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label text="Prefijo Código:" />
                                                <TextField fx:id="codigoEspacioField" promptText="E-" GridPane.columnIndex="1" />

                                                <Label text="Tipo:" GridPane.rowIndex="1" />
                                                <ComboBox fx:id="tipoEspacioCombo" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="CARRO" />
                                                            <String fx:value="MOTO" />
                                                            <String fx:value="BICICLETA" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>

                                                <Label text="Cantidad a crear:" GridPane.rowIndex="2" />
                                                <TextField fx:id="cantidadEspaciosField" promptText="1" text="1" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                            </children>
                                        </GridPane>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button onAction="#handleRegistrarEspacio" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Registrar Múltiples" />
                                                <Button onAction="#handlePonerEnMantenimiento" style="-fx-background-color: #f39c12; -fx-text-fill: white;" text="Mantenimiento (ON/OFF)" />
                                                <Button onAction="#handleEliminarEspacio" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Eliminar Seleccionado" />
                                            </children>
                                        </HBox>
                                        <Separator />
                                        <TableView fx:id="tablaEspacios" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colCodigoEspacio" prefWidth="150.0" text="Código" />
                                                <TableColumn fx:id="colTipoEspacio" prefWidth="150.0" text="Tipo" />
                                                <TableColumn fx:id="colEstadoEspacio" prefWidth="150.0" text="Estado" />
                                            </columns>
                                        </TableView>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="Tarifas">
                            <content>
                                <VBox spacing="15.0">
                                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                                    <children>
                                        <Label text="CONFIGURAR PRECIOS"><font><Font name="System Bold" size="14.0" /></font></Label>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label text="Carro ($/h):" />
                                                <TextField fx:id="tarifaCarroField" GridPane.columnIndex="1" />
                                                <Label text="Moto ($/h):" GridPane.rowIndex="1" />
                                                <TextField fx:id="tarifaMotoField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label text="Bici ($/h):" GridPane.rowIndex="2" />
                                                <TextField fx:id="tarifaBiciField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                            </children>
                                        </GridPane>
                                        <Button onAction="#handleGuardarTarifas" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Guardar Tarifas" />
                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="Usuarios Autorizados">
                            <content>
                                <VBox spacing="15.0">
                                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                                    <children>
                                        <Label text="NUEVO USUARIO"><font><Font name="System Bold" size="14.0" /></font></Label>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label text="Nombre:" />
                                                <TextField fx:id="nombreUsuarioAutField" promptText="Nombre completo" GridPane.columnIndex="1" />
                                                <Label text="ID (Cédula):" GridPane.rowIndex="1" />
                                                <TextField fx:id="identificacionUsuarioAutField" promptText="Solo números" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                <Label text="Tipo Usuario:" GridPane.rowIndex="2" />
                                                <ComboBox fx:id="tipoUsuarioAutCombo" prefWidth="200.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                                    <items>
                                                        <FXCollections fx:factory="observableArrayList">
                                                            <String fx:value="ESTUDIANTE" />
                                                            <String fx:value="DOCENTE" />
                                                            <String fx:value="ADMINISTRATIVO" />
                                                        </FXCollections>
                                                    </items>
                                                </ComboBox>
                                            </children>
                                        </GridPane>
                                        <Button onAction="#handleRegistrarUsuarioAutorizado" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="Crear Usuario" />
                                        <Separator />
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <TextField fx:id="buscarUsuarioAutField" prefWidth="250.0" promptText="Buscar por nombre o ID..." />
                                                <Button onAction="#handleBuscarUsuario" text="Buscar" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tablaUsuariosAutorizados" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colNombreUsuarioAut" prefWidth="200.0" text="Nombre" />
                                                <TableColumn fx:id="colIdentificacionUsuarioAut" prefWidth="150.0" text="ID" />
                                                <TableColumn fx:id="colTipoUsuarioAut" prefWidth="150.0" text="Tipo Usuario" />
                                            </columns>
                                        </TableView>
                                        <HBox alignment="CENTER_RIGHT">
                                            <Button onAction="#handleEliminarUsuario" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Eliminar Seleccionado" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>

                        <Tab text="Operadores">
                            <content>
                                <VBox spacing="15.0">
                                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                                    <children>
                                        <Label text="NUEVO OPERADOR"><font><Font name="System Bold" size="14.0" /></font></Label>
                                        <GridPane hgap="10.0" vgap="10.0">
                                            <children>
                                                <Label text="Nombre Usuario:" />
                                                <TextField fx:id="userAdminField" promptText="Nombre para login" GridPane.columnIndex="1" />
                                                <Label text="Contraseña:" GridPane.rowIndex="1" />
                                                <PasswordField fx:id="codigoAdminField" promptText="Clave de seguridad" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                            </children>
                                        </GridPane>
                                        <Button onAction="#handleRegistrarAdmin" style="-fx-background-color: #2980b9; -fx-text-fill: white;" text="Crear Operador" />
                                        <Separator />
                                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                                            <children>
                                                <TextField fx:id="buscarOperadorField" prefWidth="250.0" promptText="Buscar por usuario..." />
                                                <Button onAction="#handleBuscarOperador" text="Buscar" />
                                            </children>
                                        </HBox>
                                        <TableView fx:id="tablaOperadores" VBox.vgrow="ALWAYS">
                                            <columns>
                                                <TableColumn fx:id="colUserOperador" prefWidth="300.0" text="Nombre de Usuario" />
                                            </columns>
                                        </TableView>
                                        <HBox alignment="CENTER_RIGHT">
                                            <Button onAction="#handleEliminarOperador" style="-fx-background-color: #c0392b; -fx-text-fill: white;" text="Eliminar Seleccionado" />
                                        </HBox>
                                    </children>
                                </VBox>
                            </content>
                        </Tab>
                    </tabs>
                </TabPane>
            </children>
            <padding><Insets bottom="10.0" left="10.0" right="10.0" top="10.0" /></padding>
        </VBox>
    </children>
</AnchorPane>